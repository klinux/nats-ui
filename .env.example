# NATS UI Configuration
# Copy this file to .env and adjust values

# Backend
PORT=8080
BASE_URL=http://localhost:8080

# NATS connection
NATS_URL=nats://nats:4222
NATS_USER=admin
NATS_PASS=nats-secret

# UI authentication
ADMIN_USER=admin
ADMIN_PASS=admin
JWT_SECRET=change-me-in-production

# OAuth2 - Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 - GitHub (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Keycloak (optional)
KEYCLOAK_URL=
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Generic OIDC (optional) — uses .well-known/openid-configuration discovery
OIDC_NAME=SSO
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile

# Comma-separated emails allowed via OAuth2, or * for all
ALLOWED_OAUTH2_USERS=*
